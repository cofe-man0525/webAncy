LLM_MODEL=deepseek-chat
AGENT_LLM_ROUTER=false
AGENT_MEMORY_LIMIT=5
VECTOR_RAG_ENABLED=true
WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=tavily
WEB_SEARCH_API_KEY=
WEB_SEARCH_MAX_RESULTS=3
WEB_SEARCH_SENTENCE_LIMIT=6
