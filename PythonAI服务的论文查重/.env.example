APP_NAME=papercheck-ai-agent
MYSQL_URL=mysql+pymysql://root:root@localhost:3306/papercheck_agent?charset=utf8mb4
REDIS_URL=redis://localhost:6379/0
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_QUEUE=papercheck.analysis.queue
JAVA_BACKEND_ROOT=D:/桌面文件/agent论文查重后端java
RABBITMQ_AUTOSTART=true
LLM_BASE_URL=https://api.deepseek.com/v1
